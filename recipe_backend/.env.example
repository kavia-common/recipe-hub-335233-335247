# Backend required secrets/configs (DO NOT commit real values)
JWT_SECRET=change-me
JWT_ISSUER=recipe-hub-backend
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional override for cross-container DB connection file location.
# By default the backend reads ../recipe_database/db_connection.txt in this workspace layout.
RECIPE_DB_CONNECTION_FILE=/absolute/path/to/recipe_database/db_connection.txt
